class Solution {
public:
    string longestCommonPrefix(vector<string>& strs) {
        for (int i = 0; i < strs[0].size(); i++) {
            char c = strs[0][i];

            for (int j = 1; j < strs.size(); j++) {
                if (i >= strs[j].size() || strs[j][i] != c) {
                    return strs[0].substr(0, i);
                }
            }
        }

        return strs[0];
    }
};
/* The thought process behind this approach was We take the first letter of the first word in the string and compare that word with every other string's first word
if they match we move forward with the second letter of the first word and the second letter of the adjacent word as well
and if they don't match the amount of times they matched would be our longest common prefix. for e.g [ "Rehan" , "Reyan"] here the longest
common prefix is 2 [" Re "] as the first and second letter from the words match each other.*/
