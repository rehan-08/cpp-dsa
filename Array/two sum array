class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        
        for (int i = 0; i < nums.size(); i++) {
            
            for (int j = i + 1; j < nums.size(); j++) {
                
                if (nums[i] + nums[j] == target) {
                    return {i, j};
                }
            }
        }
        
        return {};
    }
};
/* used brute force in this problem instead of hashmap/hashtable which was the most efficient.
Current Complexity is O(n2) should've been O(n). Runtime is 40 ms would decrease after using hashmap.*/
